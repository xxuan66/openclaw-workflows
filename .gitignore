# ===== 通用排除项 =====
# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Node modules
node_modules/

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/

# Build outputs
dist/
build/

# Temporary files
tmp/
temp/
*.tmp

# Backup files
*.bak
*.backup

# ===== 敏感信息 =====
# Credentials
*.env
*.secret
*.key
*.pem
*.crt
credentials.json
token.json
auth.json
*.local.json
config.local.*

# ===== OpenClaw 私人配置（所有仓库必须排除）=====
.openclaw/
AGENTS.md
SOUL.md
USER.md
TOOLS.md
HEARTBEAT.md
IDENTITY.md
BOOTSTRAP.md
memory/

# ===== OpenClaw 工作目录（所有仓库必须排除）=====
skills/
scripts/
github-repos/
github-ops/
github-stats/
logs/
projects/
content/
docs/
paper_reading_notes/
.clawhub/

# ===== 微信运营（所有仓库必须排除）=====
wechat_articles/
wechat_daily/
output/
WECHAT_*.md

